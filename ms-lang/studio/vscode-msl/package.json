{
  "name": "msl-vscode",
  "displayName": "MSL Language Support",
  "description": "Language support for MSL (Macincode Scripting Language)",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:msl"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "msl",
      "aliases": ["MSL", "msl"],
      "extensions": [".msl"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "msl",
      "scopeName": "source.msl",
      "path": "./syntaxes/msl.tmLanguage.json"
    }],
    "commands": [
      {
        "command": "msl.runScript",
        "title": "Run MSL Script",
        "category": "MSL"
      },
      {
        "command": "msl.openRepl",
        "title": "Open MSL REPL",
        "category": "MSL"
      },
      {
        "command": "msl.serveAsApi",
        "title": "Serve as API",
        "category": "MSL"
      }
    ],
    "keybindings": [
      {
        "command": "msl.runScript",
        "key": "ctrl+f5",
        "when": "editorTextFocus && resourceExtname == .msl"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "MSL Configuration",
      "properties": {
        "msl.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python executable"
        },
        "msl.mslPath": {
          "type": "string",
          "default": "",
          "description": "Path to MSL CLI"
        },
        "msl.aiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API Key for AI features"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}