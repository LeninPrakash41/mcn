{
  "name": "auth",
  "version": "1.0.0",
  "description": "Authentication and authorization system",
  "functions": {
    "auth_setup": {
      "description": "Setup authentication method",
      "parameters": ["method", "config"],
      "example": "auth_setup(\"jwt\", {\"secret\": env(\"JWT_SECRET\")})"
    },
    "auth_provider": {
      "description": "Add OAuth provider",
      "parameters": ["provider", "config"],
      "example": "auth_provider(\"google\", {\"client_id\": env(\"GOOGLE_CLIENT_ID\")})"
    },
    "auth_check": {
      "description": "Verify authentication token",
      "parameters": ["token"],
      "example": "auth_check(request_data.token)"
    },
    "auth_login": {
      "description": "Authenticate user",
      "parameters": ["credentials"],
      "example": "auth_login({\"email\": \"user@example.com\", \"password\": \"pass\"})"
    },
    "auth_logout": {
      "description": "Logout user",
      "parameters": ["token"],
      "example": "auth_logout(user_token)"
    }
  }
}