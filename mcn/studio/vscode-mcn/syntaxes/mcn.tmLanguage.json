{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MCN",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [{
        "name": "keyword.control.mcn",
        "match": "\\b(var|if|else|while|for|try|catch|throw|function|return)\\b"
      }]
    },
    "functions": {
      "patterns": [{
        "name": "entity.name.function.mcn",
        "match": "\\b(log|query|trigger|ai|workflow|use|task|await|type|batch_insert|analyze_sentiment|summarize)\\b"
      }]
    },
    "strings": {
      "name": "string.quoted.double.mcn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mcn",
          "match": "\\\\."
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mcn",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mcn",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.mcn",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "operators": {
      "patterns": [{
        "name": "keyword.operator.mcn",
        "match": "(\\+|\\-|\\*|\\/|==|!=|>|<|>=|<=|=|and|or|not)"
      }]
    }
  },
  "scopeName": "source.mcn"
}
