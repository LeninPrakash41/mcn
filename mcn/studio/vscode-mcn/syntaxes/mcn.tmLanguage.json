{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MCN",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings_triple" },
    { "include": "#strings" },
    { "include": "#domain_keywords" },
    { "include": "#control_keywords" },
    { "include": "#ai_builtins" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#safe_nav" },
    { "include": "#interpolation_marker" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mcn",
          "match": "//.*$"
        }
      ]
    },

    "strings_triple": {
      "name": "string.quoted.triple.mcn",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "patterns": [
        { "include": "#interpolation" }
      ]
    },

    "strings": {
      "name": "string.quoted.double.mcn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mcn",
          "match": "\\\\."
        },
        { "include": "#interpolation" }
      ]
    },

    "interpolation": {
      "patterns": [
        {
          "name": "variable.other.interpolated.mcn",
          "match": "\\{[a-zA-Z_][a-zA-Z0-9_]*\\}"
        }
      ]
    },

    "interpolation_marker": {
      "comment": "Highlight {var} outside strings too (e.g. in prompt blocks)",
      "patterns": []
    },

    "domain_keywords": {
      "patterns": [
        {
          "name": "storage.type.mcn",
          "match": "\\b(contract|pipeline|service|workflow|prompt|agent)\\b"
        },
        {
          "name": "keyword.control.block.mcn",
          "match": "\\b(stage|endpoint|step|task)\\b"
        },
        {
          "name": "keyword.other.mcn",
          "match": "\\b(test|assert|use|import|export)\\b"
        }
      ]
    },

    "control_keywords": {
      "patterns": [
        {
          "name": "keyword.control.mcn",
          "match": "\\b(if|else|for|while|return|break|continue|try|catch|throw|in)\\b"
        },
        {
          "name": "keyword.declaration.mcn",
          "match": "\\b(var|function)\\b"
        },
        {
          "name": "keyword.operator.logical.mcn",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },

    "ai_builtins": {
      "name": "support.function.ai.mcn",
      "match": "\\b(ai|llm|embed|extract|classify|checkpoint)\\b"
    },

    "builtins": {
      "name": "support.function.builtin.mcn",
      "match": "\\b(log|echo|fetch|trigger|query|read_file|write_file|append_file|env)\\b"
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.mcn",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },

    "numbers": {
      "name": "constant.numeric.mcn",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },

    "safe_nav": {
      "name": "keyword.operator.safe-navigation.mcn",
      "match": "\\?\\."
    },

    "operators": {
      "name": "keyword.operator.mcn",
      "match": "(==|!=|>=|<=|>|<|\\+|-|\\*|\\/|=)"
    }

  },
  "scopeName": "source.mcn"
}
