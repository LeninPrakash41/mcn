{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MCN",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mcn",
          "match": "\\b(var|if|else|while|for|in|try|catch|throw|function|return|task|await|use)\\b"
        },
        {
          "name": "keyword.other.mcn",
          "match": "\\b(event|handle|create|activate|think|register|set_model|run|train|predict)\\b"
        },
        {
          "name": "storage.type.mcn",
          "match": "\\b(true|false|null|undefined)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [{
        "name": "entity.name.function.mcn",
        "match": "\\b(log|echo|query|trigger|ai|workflow|use|task|await|type|on|device|agent|pipeline|translate|ui|register|set_model|run|train|predict|load_dataset|preprocess|deploy_model|batch_predict|compare_models|export_model|fine_tune|get_training_status|generate_postman|http|track|get|store|retrieve|create_user|authenticate|analyze_sentiment|summarize|batch_insert|now|format_date|hash_data|encode_base64|decode_base64|send_email|read_file|write_file|append_file|fetch|env|typeof|len|str|int|float|bool|list|dict|abs|min|max|round|sum|range|split|join|replace|upper|lower|trim|push|pop|slice|indexOf|includes|keys|values|hasKey|random|sleep|print)\\b"
      }]
    },
    "strings": {
      "name": "string.quoted.double.mcn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mcn",
          "match": "\\\\."
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mcn",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mcn",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.mcn",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.mcn",
          "match": "(\\+|\\-|\\*|\\/|%)"
        },
        {
          "name": "keyword.operator.comparison.mcn",
          "match": "(==|!=|>|<|>=|<=)"
        },
        {
          "name": "keyword.operator.logical.mcn",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.assignment.mcn",
          "match": "="
        }
      ]
    }
  },
  "scopeName": "source.mcn"
}
