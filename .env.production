# MCN Production Environment Configuration

# API Configuration
MCN_ENV=production
MCN_PORT=8080
MCN_DEBUG=false
MCN_ENABLE_CORS=true

# Security Settings
MCN_MAX_FILE_SIZE=10485760
MCN_ALLOWED_EXTENSIONS=.mcn,.json,.csv
MCN_RATE_LIMIT=100

# Database Configuration
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://mcn_user:${DB_PASSWORD}@mcn-database:5432/mcn_production

# AI Provider Keys (set these in your environment)
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# GOOGLE_AI_KEY=your_google_key

# Monitoring
MCN_LOG_LEVEL=INFO
MCN_METRICS_ENABLED=true

# Performance
MCN_WORKER_THREADS=10
MCN_REQUEST_TIMEOUT=30