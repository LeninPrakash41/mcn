// Complete ML System Example - MCN v3.0
// Demonstrates full ML pipeline with real implementations

use "ai"
use "db"

log "=== MCN ML System Complete Example ==="

// 1. Load and prepare dataset
log "Loading customer dataset..."
var dataset_result = load_dataset("customers", "data/customers.csv")
log dataset_result

// 2. Preprocess the data
log "Preprocessing dataset..."
var preprocess_ops = [
    {"type": "drop_nulls"},
    {"type": "fill_nulls", "strategy": "mean", "columns": ["age", "income"]},
    {"type": "normalize", "columns": ["age", "income", "spending_score"]},
    {"type": "encode_categorical", "method": "label", "columns": ["gender", "category"]}
]

var preprocess_result = preprocess("customers", preprocess_ops)
log preprocess_result

// 3. Train multiple models and compare
log "Training and comparing models..."
var model_comparison = compare_models("customers", "churn", ["linear_regression", "random_forest", "xgboost"])
log model_comparison

// 4. Get the best model from comparison
var best_model_id = model_comparison.best_model.model_id
log "Best model: " + best_model_id

// 5. Make individual predictions
log "Making individual predictions..."
var customer_data = {
    "age": 35,
    "income": 50000,
    "spending_score": 0.7,
    "gender": 1,
    "category": 2
}

var prediction = predict(best_model_id, customer_data)
log prediction

// 6. Deploy model as API endpoint
log "Deploying model..."
var deployment = deploy_model(best_model_id, "churn_predictor")
log deployment

// 7. Export model for external use
log "Exporting model..."
var export_result = export_model(best_model_id, "json")
log export_result

// 8. Fine-tune a language model (if training data available)
log "Fine-tuning language model..."
var fine_tune_result = fine_tune("gpt-3.5-turbo", "training_data.jsonl", "custom_churn_model", {
    "epochs": 3,
    "learning_rate": 0.0001
})
log fine_tune_result

// 9. Monitor fine-tuning progress
if fine_tune_result.job_id
    var job_status = get_training_status(fine_tune_result.job_id)
    log "Training status: " + job_status.status
    log "Progress: " + job_status.progress

// 10. Batch prediction on large dataset
log "Running batch predictions..."
var batch_result = batch_predict(best_model_id, "data/new_customers.csv", "predictions_output.csv")
log batch_result

// 11. Create and run ML pipeline
log "Creating ML pipeline..."
var pipeline_steps = [
    {
        "type": "preprocess",
        "params": {
            "operations": [
                {"type": "drop_nulls"},
                {"type": "normalize"}
            ]
        }
    },
    {
        "type": "train",
        "params": {
            "model_type": "random_forest",
            "target_column": "churn",
            "n_estimators": 100
        }
    },
    {
        "type": "evaluate",
        "params": {}
    }
]

// Note: Pipeline functionality would be accessed through the ML system
// This demonstrates the complete integration

// 12. AI-powered model analysis
var model_info = ai("Analyze this ML model performance and provide recommendations: " +
                   "Accuracy: " + prediction.probability + 
                   ", Model type: Random Forest" +
                   ", Features: age, income, spending_score")
log "AI Analysis: " + model_info

// 13. Store results in database
query("CREATE TABLE IF NOT EXISTS ml_results (id INTEGER PRIMARY KEY, model_id TEXT, accuracy REAL, created_at TIMESTAMP)")
query("INSERT INTO ml_results (model_id, accuracy, created_at) VALUES (?, ?, datetime('now'))", 
      (best_model_id, model_comparison.best_model.metrics.accuracy))

log "=== ML Pipeline Complete ==="
log "Best model deployed at: " + deployment.endpoint
log "Batch predictions saved to: " + batch_result.output_file
log "Model exported as: " + export_result.file