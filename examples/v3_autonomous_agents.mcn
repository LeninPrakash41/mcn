// MCN v3.0 - Autonomous Agents Demo

use "agents"
use "ai_v3"

// Create specialized agents
agent("create", "data_analyst", {
    "prompt": "You are a data analyst expert. Analyze data and provide insights.",
    "model": "gpt-4",
    "tools": ["query", "ai", "log"]
})

agent("create", "customer_service", {
    "prompt": "You are a helpful customer service agent. Be polite and solution-oriented.",
    "model": "gpt-3.5-turbo",
    "tools": ["send_email", "query", "log"]
})

agent("create", "security_monitor", {
    "prompt": "You are a security monitoring agent. Watch for anomalies and threats.",
    "model": "claude-3",
    "tools": ["trigger", "log", "send_email"]
})

// Activate agents
agent("activate", "data_analyst")
agent("activate", "customer_service")
agent("activate", "security_monitor")

// Simulate agent interactions
log("=== Agent Interactions Demo ===")

// Data analyst processes sales data
var sales_analysis = agent("think", "data_analyst", {
    "input": "Analyze Q4 sales data: Revenue $2.5M (up 15%), New customers: 1,200, Churn rate: 5%"
})
log("Data Analyst: " + sales_analysis)

// Customer service handles inquiry
var service_response = agent("think", "customer_service", {
    "input": "Customer complaint: Order #12345 was delayed and arrived damaged"
})
log("Customer Service: " + service_response)

// Security monitor checks system logs
var security_check = agent("think", "security_monitor", {
    "input": "System logs show 50 failed login attempts from IP 192.168.1.100 in last hour"
})
log("Security Monitor: " + security_check)

// Agent collaboration scenario
log("=== Agent Collaboration ===")

// Data analyst identifies trend
var trend_data = agent("think", "data_analyst", {
    "input": "Customer satisfaction scores dropped 10% after recent product update"
})

// Customer service agent responds to trend
var service_action = agent("think", "customer_service", {
    "input": "Data shows customer satisfaction dropped after product update. What should we do?"
})

log("Collaborative Analysis:")
log("Analyst: " + trend_data)
log("Service: " + service_action)

// Multi-agent workflow
function process_customer_issue(issue_data) {
    // Security check first
    var security_result = agent("think", "security_monitor", {
        "input": "Check if customer issue involves security concerns: " + issue_data
    })
    
    if security_result.includes("security") {
        log("Security concern detected, escalating...")
        return "ESCALATED_TO_SECURITY"
    }
    
    // Customer service handles the issue
    var service_result = agent("think", "customer_service", {
        "input": "Handle customer issue: " + issue_data
    })
    
    // Data analyst tracks patterns
    agent("think", "data_analyst", {
        "input": "Log customer issue for pattern analysis: " + issue_data
    })
    
    return service_result
}

// Test multi-agent workflow
var issue_result = process_customer_issue("Payment failed multiple times, account locked")
log("Issue Resolution: " + issue_result)

log("Autonomous agents demo completed")